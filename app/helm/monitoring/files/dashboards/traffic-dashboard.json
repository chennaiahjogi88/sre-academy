{
  "title": "Traffic — Requests, RPS & RPM",
  "uid": "traffic-throughput",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "tags": ["traffic", "rps", "rpm", "throughput"],
  "schemaVersion": 38,
  "version": 1,
  "panels": [

    {
      "type": "row",
      "title": "Summary",
      "id": 100,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Total Requests (all time)",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(http_requests_total)", "legendFormat": "Total" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "RPS (current)",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "RPS" }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "RPM (current)",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_total[1m])) * 60", "legendFormat": "RPM" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 12000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Success Rate %",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(http_requests_total{status_code=~\"2..\"}[1m])) / sum(rate(http_requests_total[1m]))",
        "legendFormat": "Success %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },

    {
      "type": "row",
      "title": "Requests Per Second (RPS)",
      "id": 200,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "RPS — Total & by Status Class",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 16, "h": 8 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "Total RPS" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[1m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[1m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total RPS" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "RPS by Route",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 6, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(http_requests_total[1m]))",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "type": "row",
      "title": "Requests Per Minute (RPM)",
      "id": 300,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "RPM — Total & by Status Class",
      "id": 20,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 8 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) * 60", "legendFormat": "Total RPM" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"2..\"}[1m])) * 60", "legendFormat": "2xx" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[1m])) * 60", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[1m])) * 60", "legendFormat": "5xx" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total RPM" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "RPM by Route",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(http_requests_total[1m])) * 60",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "type": "row",
      "title": "HTTP Status Code Breakdown",
      "id": 400,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "2xx (Total)",
      "id": 30,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 24, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(http_requests_total{status_code=~\"2..\"}[$__range]))", "legendFormat": "2xx" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "3xx (Total)",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 24, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(http_requests_total{status_code=~\"3..\"}[$__range]))", "legendFormat": "3xx" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "4xx (Total)",
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 24, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(http_requests_total{status_code=~\"4..\"}[$__range]))", "legendFormat": "4xx" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "5xx (Total)",
      "id": 33,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 24, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[$__range]))", "legendFormat": "5xx" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "piechart",
      "title": "Request Distribution by Status Class",
      "id": 34,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum(increase(http_requests_total{status_code=~\"2..\"}[$__range]))", "legendFormat": "2xx Success" },
        { "expr": "sum(increase(http_requests_total{status_code=~\"3..\"}[$__range]))", "legendFormat": "3xx Redirect" },
        { "expr": "sum(increase(http_requests_total{status_code=~\"4..\"}[$__range]))", "legendFormat": "4xx Client Error" },
        { "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[$__range]))", "legendFormat": "5xx Server Error" }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "3xx Redirect" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx Client Error" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx Server Error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "pieType": "donut", "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["percent"] } }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status Code over Time",
      "id": 35,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 28, "w": 16, "h": 8 },
      "targets": [{
        "expr": "sum by (status_code) (rate(http_requests_total[1m]))",
        "legendFormat": "{{status_code}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "type": "bargauge",
      "title": "Top Routes by Total Requests",
      "id": 36,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 6 },
      "targets": [{
        "expr": "topk(10, sum by (route) (increase(http_requests_total[$__range])))",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}